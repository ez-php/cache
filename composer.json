{
  "name": "ez-php/cache",
  "description": "Cache module for the ez-php framework — array, file, and Redis drivers with a unified interface",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Andreas Uretschnig",
      "email": "andreas.uretschnig@gmail.com"
    }
  ],
  "keywords": ["cache", "redis", "php", "framework", "ezphp"],
  "homepage": "https://github.com/ezphp/cache",
  "support": {
    "issues": "https://github.com/ezphp/cache/issues",
    "source": "https://github.com/ezphp/cache"
  },
  "require": {
    "php": "^8.5",
    "ez-php/framework": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.0",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpstan/phpstan-deprecation-rules": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "EzPhp\\Cache\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "cs": "php-cs-fixer fix",
    "analyse": "phpstan analyse",
    "test": "phpunit",
    "full": "composer analyse && composer cs && composer test"
  }
}
